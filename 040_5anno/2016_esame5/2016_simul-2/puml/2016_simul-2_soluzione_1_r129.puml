@startuml
title Fleet Management SaaS - Architettura di rete completa

left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

actor "Operatore aziendale" as OP

cloud "Internet" as INTERNET
cloud "Rete mobile 4G/5G" as MOBILE
cloud "Core network\noperatore mobile" as TELCO

node "Veicolo" as CAR {
    rectangle "Sensori / CAN bus / GPS" as SENSORI
    rectangle "Dispositivo di bordo\nCPU embedded + modem + memoria" as OBU
}

rectangle "Router di frontiera ACME" as RTR
rectangle "Firewall / NGFW perimetrale" as FW1

frame "DMZ" as DMZ {
    rectangle "Reverse Proxy / WAF /\nLoad Balancer" as RP
    rectangle "Broker MQTT" as MQTT
}

rectangle "Firewall interno /\nfiltro tra zone" as FW2

frame "Rete server interna ACME" as LAN {
    rectangle "Application Server /\nAPI / servizi applicativi" as APP
    rectangle "IAM / Audit / gestione ruoli" as IAM
    database "DB relazionale" as DB
    database "Archivio telemetria /\nTSDB" as TSDB
}

OP --> INTERNET : HTTPS
INTERNET --> RTR
RTR --> FW1
FW1 --> RP : 443/TCP
RP --> FW2
FW2 --> APP : HTTPS / API

SENSORI --> OBU
OBU --> MOBILE : MQTT/TLS o HTTPS/TLS
MOBILE --> TELCO
TELCO --> INTERNET
FW1 --> MQTT : MQTT over TLS
MQTT --> FW2
FW2 --> APP : ingestione dati / comandi

APP --> IAM
APP --> DB
APP --> TSDB

@enduml
@startuml
left to right direction
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam wrapWidth 220
skinparam maxMessageSize 200

skinparam rectangle {
    BorderColor black
}

skinparam node {
    BorderColor black
    BackgroundColor white
}

skinparam cloud {
    BorderColor black
    BackgroundColor white
}

skinparam database {
    BorderColor black
    BackgroundColor white
}

title Rete completa hotel con DMZ, VLAN e collegamento allo stabilimento

cloud "Internet" as INTERNET
node "ONT / CPE FTTH" as ONT
node "Firewall / UTM\n3 interfacce logiche\nWAN - LAN - DMZ" as FW

package "DMZ\n10.10.70.0/24" as DMZ {
    node "Server Web Pubblico\n10.10.70.10\nHTTP/HTTPS da Internet" as WEB
}

package "LAN Hotel" as LAN {

    node "Core Switch gestito\ntrunk 802.1Q" as CORE

    package "VLAN 10 - UFFICI\n10.10.10.0/24" as VLAN10 {
        node "PC reception / amministrazione" as PCUFF1
        node "PC direzione" as PCUFF2
        node "Stampante uffici" as PRN
    }

    package "VLAN 20 - SERVIZI INTERNI\n10.10.20.0/24" as VLAN20 {
        database "Server Gestionale\n10.10.20.10" as GEST
        node "NAS / Backup" as NAS
        node "Controller Wi-Fi / RADIUS\n10.10.20.30" as WIFICTRL
    }

    package "VLAN 30 - CONVEGNI\n10.10.30.0/24" as VLAN30 {
        node "AP sala convegni" as APCONF
        node "Client convegni" as CLIENTCONF
    }

    package "VLAN 40 - OSPITI HOTEL\n10.10.40.0/24" as VLAN40 {
        node "AP camere / hall / ristorante" as APGUESTHOTEL
        node "Dispositivi ospiti hotel" as GUESTHOTEL
    }

    package "VLAN 60 - COLONNINE EV\n10.10.60.0/24" as VLAN60 {
        node "Colonnina 1" as EV1
        node "Colonnina 2" as EV2
        node "Colonnina 3" as EV3
        node "Colonnina 4" as EV4
        node "Colonnina 5" as EV5
        node "Colonnina 6" as EV6
    }

    package "VLAN 80 - MANAGEMENT\n10.10.80.0/24" as VLAN80 {
        node "Switch Management" as MGSW
        node "AP Management" as MGAP
        node "Console amministrazione" as MGADMIN
    }
}

package "Collegamento verso stabilimento balneare" as LINKAREA {
    node "Bridge radio PTP A\nHotel terrazza" as PTPA
    node "Bridge radio PTP B\nStabilimento" as PTPB
}

package "Stabilimento balneare" as BEACH {

    node "Switch stabilimento" as BSW

    package "VLAN 90 - STAFF STABILIMENTO\n10.10.90.0/24" as VLAN90 {
        node "PC cassa / bar / personale" as BSTAFF
    }

    package "VLAN 50 - OSPITI SPIAGGIA\n10.10.50.0/24" as VLAN50 {
        node "AP ospiti spiaggia" as APBEACH
        node "Dispositivi ospiti spiaggia" as GUESTBEACH
    }
}

INTERNET -- ONT
ONT -- FW

FW -- WEB : WAN <-> DMZ
FW -- CORE : WAN/LAN firewalling\nrouting inter-VLAN\nNAT / ACL / logging

CORE -- PCUFF1
CORE -- PCUFF2
CORE -- PRN

CORE -- GEST
CORE -- NAS
CORE -- WIFICTRL

CORE -- APCONF
APCONF -- CLIENTCONF

CORE -- APGUESTHOTEL
APGUESTHOTEL -- GUESTHOTEL

CORE -- EV1
CORE -- EV2
CORE -- EV3
CORE -- EV4
CORE -- EV5
CORE -- EV6

CORE -- MGSW
CORE -- MGAP
CORE -- MGADMIN

CORE -- PTPA
PTPA -- PTPB : link PTP cifrato\n500 m con visibilità ottica
PTPB -- BSW

BSW -- BSTAFF
BSW -- APBEACH
APBEACH -- GUESTBEACH

note top of FW
Regole principali:
- Internet -> DMZ: consentire solo HTTP/HTTPS verso server web
- Internet -> LAN: negato
- Guest VLAN -> LAN interna: negato
- Staff stabilimento -> server gestionale: consentito
- Management -> apparati: consentito
- Colonnine EV -> solo servizi autorizzati: consentito
end note

note right of WEB
Server esposto pubblicamente.
Deve stare in DMZ e non in LAN.
end note

note bottom of GEST
Server non esposto su Internet.
Accessibile solo da reti autorizzate.
end note

note bottom of WIFICTRL
Possibile gestione autenticazione Wi-Fi,
captive portal e credenziali legate
alla prenotazione.
end note

note bottom of VLAN40
Ospiti hotel:
accesso a Internet,
nessun accesso diretto
a uffici o servizi interni.
end note

note bottom of VLAN50
Ospiti spiaggia:
stessa logica degli ospiti hotel,
identificazione centralizzata.
end note

note bottom of VLAN90
Personale stabilimento:
accesso limitato ai soli servizi utili,
ad esempio gestionale e servizi operativi.
end note

@enduml